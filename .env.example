# Environment Configuration
ENV=development
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your-secret-api-key-change-in-production

# Model Configuration
MODEL_CACHE_DIR=./models
DEFAULT_WHISPER_MODEL=base
MAX_FILE_SIZE_MB=500
ENABLE_GPU=True

# Processing
MAX_WORKERS=4
ENABLE_DIARIZATION=True

# Cache (Redis)
REDIS_URL=redis://localhost:6379/0
ENABLE_CACHING=False

# Monitoring
ENABLE_METRICS=True
LOG_LEVEL=INFO

# HuggingFace Token (for diarization)
HF_TOKEN=your-huggingface-token-here

# LLM provider (for notes, quiz, schedule, evaluation, RAG chat)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
# Optional model override. Default: openai/gpt-4o-mini (needs OpenRouter credits).
# To run WITHOUT credits, use a free model, e.g.:
#   OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=
# Optional: override the API base (defaults to OpenRouter). Any OpenAI-compatible
# endpoint works (e.g. NVIDIA NIM, a local server, etc.)
OPENROUTER_BASE_URL=
